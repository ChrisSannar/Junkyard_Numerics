# Copy to .env and fill in ONE of the two keys.
# If OPENROUTER_API_KEY is set, it takes priority over the Anthropic key.

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Anthropic direct (https://console.anthropic.com)
#ANTHROPIC_API_KEY=

# Optional model overrides (Anthropic-style ids; mapped to OpenRouter slugs automatically)
#ORIGINALISM_MODEL=claude-sonnet-5           # memo pipeline (extract + synthesize)
#ORIGINALISM_EXPAND_MODEL=claude-haiku-4-5   # search-term expansion (cheap is fine)
